stelnet server enable
ssh user jtcjxz
ssh user jtcjxz authentication-type password
ssh user jtcjxz service-type stelnet
ssh user xz4a_admin
ssh user xz4a_admin authentication-type password
ssh user xz4a_admin service-type stelnet
ssh server cipher aes256_ctr
ssh server hmac sha2_256
ssh server key-exchange dh_group_exchange_sha1
ssh client cipher aes256_ctr aes128_ctr
