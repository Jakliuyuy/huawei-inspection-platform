 authentication-scheme admin_ldap
 authentication-scheme admin_ldap_local
 authentication-scheme admin_local
 authentication-scheme admin_radius
 authentication-scheme admin_radius_local
 authentication-scheme default
 authorization-scheme default
 accounting-scheme default
 domain default
  service-type internetaccess ssl-vpn l2tp ike
  internet-access mode password
  reference user current-domain
 role system-admin
 role device-admin
 role device-admin(monitor)
 role audit-admin
#
interface Eth-Trunk1.56
 vlan-type dot1q 56
 description uT:YLSWCE101BHW GE0/0/4_GE0/0/5
 ip binding vpn-instance KeHuZiPingTai
 ip address 192.168.1.142 255.255.255.252
 service-manage ping permit
 service-manage ssh permit
 service-manage telnet permit
#
interface Eth-Trunk1.57
 vlan-type dot1q 57
 description uT:YLSWCE102BHW GE0/0/4_GE0/0/5
 ip binding vpn-instance KeHuZiPingTai
 service-manage http permit
 service-manage https permit
 service-manage ping permit
 service-manage ssh permit
 service-manage telnet permit
#
l2tp-group default-lns
#
interface GigabitEthernet0/0/7
 description insec_ins-T3 172.17.0.84 ETH2
 undo shutdown
 ip binding vpn-instance KeHuZiPingTai
 ip address 10.10.17.2 255.255.255.248
 vrrp vrid 1 virtual-ip 10.10.17.1 active
 service-manage ping permit
#
interface XGigabitEthernet0/0/0
 undo shutdown
 ip binding vpn-instance KeHuZiPingTai
#
interface XGigabitEthernet0/0/0.222
 vlan-type dot1q 222
 ip binding vpn-instance KeHuZiPingTai
 ip address 10.252.3.66 255.255.255.252
 service-manage http permit
 service-manage https permit
 service-manage ping permit
 service-manage ssh permit
 service-manage telnet permit
#
interface Virtual-if1
#
sa
#
firewall zone local
 set priority 100
#
firewall zone trust
 set priority 85
 add interface Eth-Trunk1.56
 add interface Eth-Trunk1.57
#
firewall zone untrust
 set priority 5
#
firewall zone dmz
 set priority 50
#
firewall zone name KeHuZiPingTai id 4
 set priority 10
 add interface GigabitEthernet0/0/7
#
firewall zone name zpt id 5
 set priority 4
 add interface XGigabitEthernet0/0/0.222
#
location
#
nat address-group 222 1
 mode pat
 section 0 10.252.3.66 10.252.3.66
#
multi-interface
 mode proportion-of-weight
#
security-policy
 rule name trust_local
  source-zone trust
  destination-zone local
  source-address 192.168.1.140 mask 255.255.255.252
  source-address 192.168.1.144 mask 255.255.255.252
  destination-address 192.168.1.140 mask 255.255.255.252
  destination-address 192.168.1.144 mask 255.255.255.252
  action permit
 rule name trust_KeHuZiPingTai
  source-zone trust
  destination-zone KeHuZiPingTai
  source-address 10.192.64.0 mask 255.255.248.0
  source-address 10.2.0.0 mask 255.255.0.0
  destination-address 10.10.0.0 mask 255.255.0.0
  action permit
 rule name KeHuZiPingTai_trust
  source-zone KeHuZiPingTai
  destination-zone trust
  source-address 10.10.0.0 mask 255.255.0.0
  destination-address 10.192.64.0 mask 255.255.248.0
  destination-address 10.2.0.0 mask 255.255.0.0
  action permit
 rule name KeHuZiPingTai_local
  source-zone KeHuZiPingTai
  destination-zone local
  source-address 10.10.17.0 mask 255.255.255.0
  source-address 10.10.17.0 mask 255.255.255.248
  destination-address 10.10.17.0 mask 255.255.255.0
  destination-address 10.10.17.0 mask 255.255.255.248
  action permit
 rule name local_dmz
  source-zone local
  destination-zone dmz
  source-address address-set ipv4_any
  source-address-exclude 1.1.1.1 mask 255.255.255.255
  destination-address address-set ipv4_any
  destination-address-exclude 1.1.1.1 mask 255.255.255.255
  action permit
#
auth-policy
#
traffic-policy
#
policy-based-route
#
nat-policy
#
proxy-policy
#
quota-policy
#
pcp-policy
#
ip route-static 10.10.0.0 255.255.0.0 GigabitEthernet0/0/7 10.10.17.6 description insec_ins-T3 172.17.0.84 ETH3 KeHuZiPingTai
ip route-static 10.192.64.0 255.255.248.0 Eth-Trunk1.56 192.168.1.141 description YLSWCE101BHW  VRF_N6_Local_2B_YLTK
#
firewall detect ftp
firewall detect rtsp
firewall detect pptp
#
return
